  "tour": [
    {
      "order": 1,
      "title": "Package Purpose",
      "description": "Start with DESCRIPTION to learn what copulaNetworks does: it fits and visualizes stratified nonparanormal Gaussian copula graphical models using graphical lasso with StARS model selection. The declared dependencies on huge, tidygraph, ggraph, ggplot2, and dplyr preview the statistical and visualization stack the rest of the tour will unpack.",
      "nodeIds": [
        "file:DESCRIPTION"
      ]
    },
    {
      "order": 2,
      "title": "Public API Surface",
      "description": "NAMESPACE is the contract between the package and its users, exporting 17 functions across preparation, fitting, plotting, and comparison. Reading it after DESCRIPTION shows which modules are user-facing and which external packages the implementation relies on, giving you a map before diving into pipeline.R.",
      "nodeIds": [
        "file:NAMESPACE"
      ],
      "languageLesson": "In R packages, roxygen2 comments generate NAMESPACE exports automatically. Only exported functions are part of the stable public API; unexported helpers remain internal implementation details."
    },
    {
      "order": 3,
